
# Face Attendance System — Backend Environment Variables
# Copy this to .env and edit as needed

# App
DEBUG=True

# JWT — CHANGE THIS IN PRODUCTION
JWT_SECRET=DUMMY_SECRET_CHANGE_IN_PRODUCTION_PLEASE
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Database (SQLite by default — change to PostgreSQL for production)
DATABASE_URL=sqlite:///./attendance.db

# CV Thresholds
FACE_SIMILARITY_THRESHOLD=0.55   # Cosine similarity cutoff for ArcFace
LIVENESS_THRESHOLD=0.6           # Passive liveness confidence cutoff
SPOOF_REJECTION_THRESHOLD=0.45

# Geofence
DEFAULT_ROOM_RADIUS_METERS=20.0

# SMTP — for sending real OTP emails to students
# Set SMTP_ENABLED=true and fill in credentials to send real emails.
# Without this, OTPs are shown on-screen (dev mode).
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=neilgupta04@gmail.com
SMTP_PASSWORD=xxtq baxn ieoj ojan
SMTP_FROM_NAME=Face Attendance System
# Gmail App Password: enable 2FA → https://myaccount.google.com/apppasswords
